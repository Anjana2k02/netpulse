<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Backgrounds -->
  <SolidColorBrush x:Key="BgBrush"         Color="#111111"/>
  <SolidColorBrush x:Key="SurfaceBrush"    Color="#1A1A1A"/>
  <SolidColorBrush x:Key="CardBgBrush"     Color="#1C1C1C"/>
  <SolidColorBrush x:Key="Surface2Brush"   Color="#242424"/>
  <SolidColorBrush x:Key="HoverBrush"      Color="#252525"/>
  <SolidColorBrush x:Key="BorderBrush"     Color="#2C2C2C"/>
  <SolidColorBrush x:Key="GridLineBrush"   Color="#1F1F1F"/>

  <!-- Text -->
  <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#F0F0F0"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="#808080"/>
  <SolidColorBrush x:Key="TextMutedBrush"     Color="#505050"/>

  <!-- Data colours -->
  <SolidColorBrush x:Key="DownloadBrush" Color="#60A5FA"/>
  <SolidColorBrush x:Key="UploadBrush"   Color="#F87171"/>
  <SolidColorBrush x:Key="TotalBrush"    Color="#D4D4D4"/>
  <SolidColorBrush x:Key="SpeedBrush"    Color="#4ADE80"/>

  <!-- Tab / segmented control -->
  <SolidColorBrush x:Key="TabContainerBrush"    Color="#1C1C1C"/>
  <SolidColorBrush x:Key="TabActiveBrush"       Color="#2D2D2D"/>
  <SolidColorBrush x:Key="TabActiveTextBrush"   Color="#F0F0F0"/>
  <SolidColorBrush x:Key="TabInactiveTextBrush" Color="#606060"/>
  <SolidColorBrush x:Key="TabHoverBrush"        Color="#222222"/>

  <!-- DataGrid header -->
  <SolidColorBrush x:Key="HeaderBgBrush" Color="#141414"/>
  <SolidColorBrush x:Key="HeaderFgBrush" Color="#606060"/>

  <!-- ScrollBar -->
  <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#2C2C2C"/>
  <SolidColorBrush x:Key="ScrollBarBgBrush"    Color="#141414"/>

</ResourceDictionary>
